# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# SMTP для отправки книг на Kindle
# Адрес отправителя должен быть добавлен в список одобренных
# в настройках Amazon: Content & Devices → Preferences → Personal Document Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_USE_TLS=true

# Путь к базе данных (создаётся автоматически)
DATABASE_PATH=/opt/kindle-telegram-bot/data/users.db

# Максимальный размер файла в байтах (20 МБ — лимит Telegram для ботов)
MAX_FILE_SIZE=20971520
